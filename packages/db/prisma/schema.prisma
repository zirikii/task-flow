// TaskFlow Prisma schema.
// Models: User, Session, Workspace, Membership, Project, Task, Label, TaskLabel,
// Comment, Activity. PostgreSQL datasource.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_MOVED
  TASK_ASSIGNED
  TASK_LABELED
  COMMENT_ADDED
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions      Session[]
  memberships   Membership[]
  assignedTasks Task[]       @relation("TaskAssignee")
  createdTasks  Task[]       @relation("TaskCreator")
  comments      Comment[]
  activities    Activity[]   @relation("ActivityActor")

  // Suite products
  authoredPages Page[] @relation("PageAuthor")

  @@map("users")
}

model Session {
  // `id` is the opaque session token stored (hashed) in an httpOnly cookie.
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Workspaces & membership
// ---------------------------------------------------------------------------

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  projects    Project[]
  labels      Label[]

  // Suite products
  spaces       Space[]
  trelloBoards TrelloBoard[]

  @@map("workspaces")
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// ---------------------------------------------------------------------------
// Projects & tasks
// ---------------------------------------------------------------------------

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  key         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("projects")
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(BACKLOG)
  priority    Priority   @default(NONE)
  // Fractional rank used to order tasks within a status column.
  position    Float      @default(1000)
  assigneeId  String?
  creatorId   String
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator    User        @relation("TaskCreator", fields: [creatorId], references: [id])
  labels     TaskLabel[]
  comments   Comment[]
  activities Activity[]

  @@index([projectId, status])
  @@index([assigneeId])
  @@map("tasks")
}

model Label {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String
  createdAt   DateTime @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("labels")
}

model TaskLabel {
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_labels")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("comments")
}

model Activity {
  id        String       @id @default(cuid())
  taskId    String
  actorId   String
  type      ActivityType
  // Structured details of the change (e.g. { from, to } for moves).
  data      Json         @default("{}")
  createdAt DateTime     @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("activities")
}

// ===========================================================================
// Confluence — spaces & wiki pages
// ===========================================================================

model Space {
  id          String   @id @default(cuid())
  workspaceId String
  key         String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages     Page[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("spaces")
}

model Page {
  id        String   @id @default(cuid())
  spaceId   String
  parentId  String?
  title     String
  body      String   @default("")
  authorId  String
  position  Float    @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space    Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parent   Page?  @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Page[] @relation("PageTree")
  author   User   @relation("PageAuthor", fields: [authorId], references: [id])

  @@index([spaceId])
  @@index([parentId])
  @@map("pages")
}

// ===========================================================================
// Trello — boards, lists & cards
// ===========================================================================

model TrelloBoard {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lists     TrelloList[]

  @@index([workspaceId])
  @@map("trello_boards")
}

model TrelloList {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Float    @default(1000)
  createdAt DateTime @default(now())

  board TrelloBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards TrelloCard[]

  @@index([boardId])
  @@map("trello_lists")
}

model TrelloCard {
  id          String   @id @default(cuid())
  listId      String
  title       String
  description String?
  position    Float    @default(1000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  list TrelloList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("trello_cards")
}
