// TaskFlow Prisma schema.
// Models: User, Session, Workspace, Membership, Project, Task, Label, TaskLabel,
// Comment, Activity. PostgreSQL datasource.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_MOVED
  TASK_ASSIGNED
  TASK_LABELED
  COMMENT_ADDED
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions      Session[]
  memberships   Membership[]
  assignedTasks Task[]       @relation("TaskAssignee")
  createdTasks  Task[]       @relation("TaskCreator")
  comments      Comment[]
  activities    Activity[]   @relation("ActivityActor")

  // Suite products
  authoredPages    Page[]           @relation("PageAuthor")
  incidentUpdates  IncidentUpdate[] @relation("IncidentUpdateAuthor")
  reportedRequests ServiceRequest[] @relation("RequestReporter")
  assignedRequests ServiceRequest[] @relation("RequestAssignee")
  requestComments  RequestComment[] @relation("RequestCommentAuthor")
  createdIdeas     Idea[]           @relation("IdeaCreator")
  ideaVotes        IdeaVote[]
  ackedAlerts      Alert[]          @relation("AlertAckedBy")
  onCallShifts     OnCallShift[]

  @@map("users")
}

model Session {
  // `id` is the opaque session token stored (hashed) in an httpOnly cookie.
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Workspaces & membership
// ---------------------------------------------------------------------------

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  projects    Project[]
  labels      Label[]

  // Suite products
  spaces       Space[]
  trelloBoards TrelloBoard[]
  statusPages  StatusPage[]
  serviceDesks    ServiceDesk[]
  ideaBoards      IdeaBoard[]
  alerts          Alert[]
  onCallSchedules OnCallSchedule[]

  @@map("workspaces")
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// ---------------------------------------------------------------------------
// Projects & tasks
// ---------------------------------------------------------------------------

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  key         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("projects")
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(BACKLOG)
  priority    Priority   @default(NONE)
  // Fractional rank used to order tasks within a status column.
  position    Float      @default(1000)
  assigneeId  String?
  creatorId   String
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator    User        @relation("TaskCreator", fields: [creatorId], references: [id])
  labels     TaskLabel[]
  comments   Comment[]
  activities Activity[]

  @@index([projectId, status])
  @@index([assigneeId])
  @@map("tasks")
}

model Label {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String
  createdAt   DateTime @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("labels")
}

model TaskLabel {
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
  @@map("task_labels")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("comments")
}

model Activity {
  id        String       @id @default(cuid())
  taskId    String
  actorId   String
  type      ActivityType
  // Structured details of the change (e.g. { from, to } for moves).
  data      Json         @default("{}")
  createdAt DateTime     @default(now())

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("activities")
}

// ===========================================================================
// Confluence — spaces & wiki pages
// ===========================================================================

model Space {
  id          String   @id @default(cuid())
  workspaceId String
  key         String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages     Page[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("spaces")
}

model Page {
  id        String   @id @default(cuid())
  spaceId   String
  parentId  String?
  title     String
  body      String   @default("")
  authorId  String
  position  Float    @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  space    Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  parent   Page?  @relation("PageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Page[] @relation("PageTree")
  author   User   @relation("PageAuthor", fields: [authorId], references: [id])

  @@index([spaceId])
  @@index([parentId])
  @@map("pages")
}

// ===========================================================================
// Trello — boards, lists & cards
// ===========================================================================

model TrelloBoard {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lists     TrelloList[]

  @@index([workspaceId])
  @@map("trello_boards")
}

model TrelloList {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Float    @default(1000)
  createdAt DateTime @default(now())

  board TrelloBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards TrelloCard[]

  @@index([boardId])
  @@map("trello_lists")
}

model TrelloCard {
  id          String   @id @default(cuid())
  listId      String
  title       String
  description String?
  position    Float    @default(1000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  list TrelloList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("trello_cards")
}

// ===========================================================================
// Statuspage — components & incidents
// ===========================================================================

enum ComponentStatus {
  OPERATIONAL
  DEGRADED
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
}

enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum IncidentImpact {
  MINOR
  MAJOR
  CRITICAL
}

model StatusPage {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  components StatusComponent[]
  incidents  StatusIncident[]

  @@index([workspaceId])
  @@map("status_pages")
}

model StatusComponent {
  id        String          @id @default(cuid())
  pageId    String
  name      String
  status    ComponentStatus @default(OPERATIONAL)
  position  Float           @default(1000)
  createdAt DateTime        @default(now())

  page StatusPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("status_components")
}

model StatusIncident {
  id        String         @id @default(cuid())
  pageId    String
  title     String
  status    IncidentStatus @default(INVESTIGATING)
  impact    IncidentImpact @default(MINOR)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  page    StatusPage       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  updates IncidentUpdate[]

  @@index([pageId])
  @@map("status_incidents")
}

model IncidentUpdate {
  id         String         @id @default(cuid())
  incidentId String
  body       String
  status     IncidentStatus
  authorId   String
  createdAt  DateTime       @default(now())

  incident StatusIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  author   User           @relation("IncidentUpdateAuthor", fields: [authorId], references: [id])

  @@index([incidentId])
  @@map("incident_updates")
}

// ===========================================================================
// Jira Service Management — service desks, request types & requests
// ===========================================================================

enum RequestStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
}

model ServiceDesk {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())

  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestTypes RequestType[]
  requests     ServiceRequest[]

  @@index([workspaceId])
  @@map("service_desks")
}

model RequestType {
  id          String   @id @default(cuid())
  serviceDeskId String
  name        String
  description String?
  createdAt   DateTime @default(now())

  serviceDesk ServiceDesk      @relation(fields: [serviceDeskId], references: [id], onDelete: Cascade)
  requests    ServiceRequest[]

  @@index([serviceDeskId])
  @@map("request_types")
}

model ServiceRequest {
  id            String        @id @default(cuid())
  serviceDeskId String
  requestTypeId String
  summary       String
  description   String?
  status        RequestStatus @default(OPEN)
  priority      Priority      @default(MEDIUM)
  reporterId    String
  assigneeId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  serviceDesk ServiceDesk      @relation(fields: [serviceDeskId], references: [id], onDelete: Cascade)
  requestType RequestType      @relation(fields: [requestTypeId], references: [id])
  reporter    User             @relation("RequestReporter", fields: [reporterId], references: [id])
  assignee    User?            @relation("RequestAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments    RequestComment[]

  @@index([serviceDeskId, status])
  @@map("service_requests")
}

model RequestComment {
  id        String   @id @default(cuid())
  requestId String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User           @relation("RequestCommentAuthor", fields: [authorId], references: [id])

  @@index([requestId])
  @@map("request_comments")
}

// ===========================================================================
// Jira Product Discovery — idea boards, ideas & votes
// ===========================================================================

enum IdeaStatus {
  NEW
  UNDER_REVIEW
  PLANNED
  SHIPPED
}

model IdeaBoard {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ideas     Idea[]

  @@index([workspaceId])
  @@map("idea_boards")
}

model Idea {
  id          String     @id @default(cuid())
  boardId     String
  title       String
  description String?
  impact      Int        @default(3)
  effort      Int        @default(3)
  status      IdeaStatus @default(NEW)
  creatorId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  board   IdeaBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  creator User       @relation("IdeaCreator", fields: [creatorId], references: [id])
  votes   IdeaVote[]

  @@index([boardId])
  @@map("ideas")
}

model IdeaVote {
  ideaId    String
  userId    String
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([ideaId, userId])
  @@index([userId])
  @@map("idea_votes")
}

// ===========================================================================
// Opsgenie — alerts & on-call schedules
// ===========================================================================

enum AlertPriority {
  P1
  P2
  P3
  P4
  P5
}

enum AlertStatus {
  OPEN
  ACKED
  CLOSED
}

model Alert {
  id          String        @id @default(cuid())
  workspaceId String
  message     String
  priority    AlertPriority @default(P3)
  status      AlertStatus   @default(OPEN)
  source      String        @default("manual")
  ackedById   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ackedBy   User?     @relation("AlertAckedBy", fields: [ackedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@map("alerts")
}

model OnCallSchedule {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  shifts    OnCallShift[]

  @@index([workspaceId])
  @@map("oncall_schedules")
}

model OnCallShift {
  id         String   @id @default(cuid())
  scheduleId String
  userId     String
  startsAt   DateTime
  endsAt     DateTime

  schedule OnCallSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("oncall_shifts")
}
