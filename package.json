{
  "name": "taskflow",
  "version": "0.1.0",
  "private": true,
  "description": "TaskFlow — a production-grade monorepo team task tracker (Linear-lite).",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "pnpm --filter @taskflow/db db:generate",
    "db:migrate": "pnpm --filter @taskflow/db db:migrate",
    "db:migrate:deploy": "pnpm --filter @taskflow/db db:migrate:deploy",
    "db:seed": "pnpm --filter @taskflow/db db:seed",
    "db:studio": "pnpm --filter @taskflow/db db:studio",
    "db:reset": "pnpm --filter @taskflow/db db:reset"
  },
  "devDependencies": {
    "prettier": "3.9.1",
    "turbo": "2.10.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "unrs-resolver", "@node-rs/argon2"]
  }
}
