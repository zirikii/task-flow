{
  "name": "@taskflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    }
  },
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "dotenv -e ../../.env -- vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/websocket": "11.2.0",
    "@node-rs/argon2": "2.0.2",
    "@taskflow/db": "workspace:*",
    "@taskflow/types": "workspace:*",
    "@trpc/server": "11.18.0",
    "fastify": "5.9.0",
    "pino-pretty": "13.1.3",
    "superjson": "2.2.6",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@taskflow/config": "workspace:*",
    "@types/node": "^22.12.0",
    "@types/ws": "8.18.1",
    "dotenv-cli": "11.0.0",
    "eslint": "9.39.4",
    "tsup": "8.5.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
