# ----------------------------------------------------------------------------
# TaskFlow environment variables. Copy to `.env` and adjust as needed.
# ----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma (packages/db) and the API.
DATABASE_URL="postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public"

# Separate database used by the integration test suite.
DATABASE_URL_TEST="postgresql://taskflow:taskflow@localhost:5432/taskflow_test?schema=public"

# API server (Fastify + tRPC)
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
SESSION_COOKIE_NAME="taskflow_session"

# Web app (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000"

# ----------------------------------------------------------------------------
# Product suite app origins (used by the app switcher). Each product is a
# separate Next.js app on its own port; they share one API + one session.
# CORS also allows any http://localhost:<port> in development.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_JIRA_URL="http://localhost:3000" # pragma: allowlist secret
NEXT_PUBLIC_CONFLUENCE_URL="http://localhost:3001"
NEXT_PUBLIC_TRELLO_URL="http://localhost:3002"
NEXT_PUBLIC_SERVICEDESK_URL="http://localhost:3003"
NEXT_PUBLIC_DISCOVERY_URL="http://localhost:3004"
NEXT_PUBLIC_STATUSPAGE_URL="http://localhost:3005"
NEXT_PUBLIC_OPSGENIE_URL="http://localhost:3006"
NEXT_PUBLIC_COMPASS_URL="http://localhost:3007"
NEXT_PUBLIC_BITBUCKET_URL="http://localhost:3008"
NEXT_PUBLIC_ATLAS_URL="http://localhost:3009"
NEXT_PUBLIC_HOME_URL="http://localhost:3010"
