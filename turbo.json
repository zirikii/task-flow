{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", "tsconfig.json"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DATABASE_URL_TEST",
    "API_PORT",
    "WEB_PORT",
    "SESSION_COOKIE_NAME",
    "CORS_ORIGIN",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL",
    "NEXT_PUBLIC_JIRA_URL",
    "NEXT_PUBLIC_CONFLUENCE_URL",
    "NEXT_PUBLIC_TRELLO_URL",
    "NEXT_PUBLIC_SERVICEDESK_URL",
    "NEXT_PUBLIC_DISCOVERY_URL",
    "NEXT_PUBLIC_STATUSPAGE_URL",
    "NEXT_PUBLIC_OPSGENIE_URL",
    "NEXT_PUBLIC_COMPASS_URL",
    "NEXT_PUBLIC_BITBUCKET_URL",
    "NEXT_PUBLIC_ATLAS_URL",
    "NEXT_PUBLIC_HOME_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
